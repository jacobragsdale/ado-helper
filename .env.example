# Copy to .env and fill in. Loaded automatically at startup; CLI flags override these.

# Full org URL (no trailing slash)
ADO_ORG_URL=https://dev.azure.com/your-org

# Default project name used when --project is not passed
ADO_PROJECT=your-project

# Optional default repository name for PR commands
ADO_REPO=your-repo

# Personal Access Token — create from your Azure DevOps user settings
ADO_PAT=
